@model IEnumerable<DindPoint.Application.DTOs.Department.DepartmentDto>
@{ ViewData["Title"] = "Department Management"; }

<div class="space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Department Management</h2>
            <p class="text-sm text-slate-500 mt-1">Kelola struktur departemen dan pelaporan.</p>
        </div>
        <a asp-action="Create" class="btn-primary inline-flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Tambah Department
        </a>
    </div>

    <div class="hidden md:block table-container overflow-x-auto">
        <div class="min-w-max">
            <table class="min-w-full divide-y divide-slate-200">
                <thead>
                    <tr>
                        <th class="table-header">ID</th>
                        <th class="table-header">Department Name</th>
                        <th class="table-header hidden lg:table-cell">Head of Dept</th>
                        <th class="table-header hidden lg:table-cell">Parent Dept</th>
                        <th class="table-header text-center">Status</th>
                        <th class="table-header text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-100">
                    @foreach (var item in Model)
                    {
                        <tr class="table-row">
                            <td class="table-cell text-slate-400">@item.Id</td>
                            <td class="table-cell font-medium text-slate-900">@item.DepartmentName</td>
                            <td class="table-cell text-slate-500 hidden lg:table-cell">
                                @(item.HeadOfDepartmentId.HasValue ? $"User #{item.HeadOfDepartmentId}" : "-")
                            </td>
                            <td class="table-cell text-slate-500 hidden lg:table-cell">
                                @(item.ParentDepartmentId.HasValue ? $"Dept #{item.ParentDepartmentId}" : "-")
                            </td>
                            <td class="table-cell text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge badge-success px-3 py-1 text-xs font-semibold">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger px-3 py-1 text-xs font-semibold">Inactive</span>
                                }
                            </td>
                            <td class="table-cell text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-btn-edit" title="Edit">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <button type="button" onclick="confirmDelete(@item.Id)" class="action-btn action-btn-delete" title="Delete">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                    <form id="delete-form-@item.Id" asp-action="Delete" asp-route-id="@item.Id" class="hidden">
                                        @Html.AntiForgeryToken()
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="md:hidden space-y-3">
        @foreach (var item in Model)
        {
            <div class="card p-4 space-y-3">
                <div class="flex justify-between items-start">
                    <div>
                        <div class="text-xs text-slate-400 mb-1">ID: @item.Id</div>
                        <h3 class="font-semibold text-slate-900 text-lg">@item.DepartmentName</h3>
                        <p class="text-sm text-slate-500 mt-1">
                            HOD: @(item.HeadOfDepartmentId.HasValue ? $"User #{item.HeadOfDepartmentId}" : "-") | 
                            Parent: @(item.ParentDepartmentId.HasValue ? $"Dept #{item.ParentDepartmentId}" : "-")
                        </p>
                    </div>
                    @if (item.IsActive)
                    {
                        <span class="badge badge-success px-2.5 py-1 text-xs font-semibold">Active</span>
                    }
                    else
                    {
                        <span class="badge badge-danger px-2.5 py-1 text-xs font-semibold">Inactive</span>
                    }
                </div>
                <div class="flex justify-end gap-2 pt-3 border-t border-slate-100">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-secondary text-xs px-3 py-1.5 inline-flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                        Edit
                    </a>
                    <button type="button" onclick="confirmDelete(@item.Id)" class="btn-danger text-xs px-3 py-1.5 inline-flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        Hapus
                    </button>
                    <form id="delete-form-@item.Id" asp-action="Delete" asp-route-id="@item.Id" class="hidden">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (typeof iziToast === 'undefined') {
                if (confirm('Hapus department ini? Sub-departemen dan user terkait mungkin terpengaruh.')) {
                    document.getElementById('delete-form-' + id).submit();
                }
                return;
            }
            
            iziToast.question({
                timeout: 20000,
                close: false,
                overlay: true,
                displayMode: 'once',
                id: 'question',
                zindex: 999,
                title: 'Hapus Department?',
                message: 'Sub-departemen dan user terkait mungkin terpengaruh.',
                position: 'center',
                buttons: [
                    ['<button><b>YA, HAPUS</b></button>', function (instance, toast) {
                        instance.hide({ transitionOut: 'fadeOut' }, toast, 'button');
                        document.getElementById('delete-form-' + id).submit();
                    }, true],
                    ['<button>Batal</button>', function (instance, toast) {
                        instance.hide({ transitionOut: 'fadeOut' }, toast, 'button');
                    }]
                ]
            });
        }
    </script>
}