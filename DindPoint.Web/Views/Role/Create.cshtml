@model DindPoint.Application.DTOs.Role.RoleCreateDto
@{ ViewData["Title"] = "Create Role"; }

<div class="container mx-auto px-4 py-8 max-w-2xl">
    <div class="mb-6">
        <a asp-action="Index" class="text-gray-500 hover:text-gray-700 flex items-center text-sm">
            ⬅️ Back to List
        </a>
        <h2 class="text-2xl font-bold text-gray-800 mt-2">Create New Role</h2>
    </div>

    <div class="card">
        <form asp-action="Create">
            <div class="space-y-6">
                <div class="form-group">
                    <label asp-for="RoleName" class="label-field"></label>
                    <input asp-for="RoleName" class="input-field" placeholder="e.g., Manager, Supervisor, Staff" />
                    <span asp-validation-for="RoleName" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="label-field"></label>
                    <textarea asp-for="Description" class="input-field" rows="3" placeholder="Brief description of responsibilities"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200">
                    <a asp-action="Index" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-primary">Save Role</button>
                </div>
            </div>
        </form>
    </div>
</div>