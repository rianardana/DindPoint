@model DindPoint.Application.DTOs.Role.RoleCreateDto
@{ ViewData["Title"] = "Create Role"; }

<div class="min-h-screen bg-slate-50 py-8">
    <div class="container mx-auto px-4 max-w-2xl">
        
        <!-- Breadcrumb + Header -->
        <div class="mb-8">
            <a asp-action="Index" class="inline-flex items-center text-sm text-slate-500 hover:text-slate-700 transition-colors mb-4">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                Back to Roles
            </a>
            <h2 class="text-2xl font-bold text-slate-800">Create New Role</h2>
            <p class="text-slate-500 text-sm mt-1">Define a new access level for system users.</p>
        </div>

        <!-- Form Card -->
        <div class="card">
            <form asp-action="Create" class="space-y-6">
                
                <div class="form-group">
                    <label asp-for="RoleName" class="label-field">Role Name <span class="text-red-500">*</span></label>
                    <input asp-for="RoleName" class="input-field" placeholder="e.g., Manager, Supervisor, Staff" />
                    <span asp-validation-for="RoleName" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="label-field">Description</label>
                    <textarea asp-for="Description" class="input-field" rows="3" placeholder="Brief description of responsibilities and permissions"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
                    <p class="text-slate-400 text-xs mt-1">Optional: helps other admins understand this role's purpose.</p>
                </div>

                <!-- Form Actions -->
                <div class="flex items-center justify-end gap-3 pt-6 border-t border-slate-200">
                    <a asp-action="Index" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-primary">Create Role</button>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}