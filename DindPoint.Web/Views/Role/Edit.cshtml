@model DindPoint.Application.DTOs.Role.RoleUpdateDto
@{ ViewData["Title"] = "Edit Role"; }

<div class="container mx-auto px-4 py-8 max-w-2xl">
    <div class="mb-6">
        <a asp-action="Index" class="text-gray-500 hover:text-gray-700 flex items-center text-sm">
            ⬅️ Back to List
        </a>
        <h2 class="text-2xl font-bold text-gray-800 mt-2">Edit Role</h2>
    </div>

    <div class="card">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div class="space-y-6">
                <div class="form-group">
                    <label asp-for="RoleName" class="label-field"></label>
                    <input asp-for="RoleName" class="input-field" />
                    <span asp-validation-for="RoleName" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="label-field"></label>
                    <textarea asp-for="Description" class="input-field" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="form-group flex items-center">
                    <input asp-for="IsActive" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
                    <label asp-for="IsActive" class="ml-2 block text-sm text-gray-900">Active Role</label>
                </div>

                <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200">
                    <a asp-action="Index" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-primary">Update Role</button>
                </div>
            </div>
        </form>
    </div>
</div>