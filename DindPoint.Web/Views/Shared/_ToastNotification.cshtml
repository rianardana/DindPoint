@if (TempData["SuccessMessage"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            iziToast.success({
                title: 'Berhasil!',
                message: '@TempData["SuccessMessage"]',
                position: 'topRight',
                timeout: 4000,
                close: true,
                closeOnClick: true,
                drag: true,
                icon: 'ico-check',
                transitionIn: 'fadeInRight',
                transitionOut: 'fadeOutRight',
                progressBar: true,
                backgroundColor: '#10b981', // Tailwind success
                titleColor: '#ffffff',
                messageColor: '#ffffff',
                iconColor: '#ffffff'
            });
        });
    </script>
}

